{
  "name": "ssahdrify-tauri",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:gui": "vite build",
    "build:engine": "esbuild src/cli-engine-entry.ts --bundle --minify --format=iife --global-name=ssaHdrifyCliEngine --target=es2020 --platform=neutral --main-fields=module,main --outfile=dist-engine/engine.js",
    "build:cli": "npm run build:engine && cargo build --release --bin ssahdrify-cli --manifest-path src-tauri/Cargo.toml",
    "build:all": "npm run build && npm run build:cli",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:rs",
    "lint:js": "eslint . && prettier --check .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "lint:fix": "eslint . --fix && prettier --write . && stylelint \"src/**/*.css\" --fix && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "ass-compiler": "0.1.16",
    "colorjs.io": "0.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "3.8.3",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "esbuild": "^0.28.0"
  }
}
