{
  "extends": "stylelint-config-standard",
  "rules": {
    "no-descending-specificity": null,
    "import-notation": "string",
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "config",
          "theme",
          "screen",
          "layer",
          "variants",
          "responsive",
          "source",
          "utility",
          "custom-variant",
          "reference"
        ]
      }
    ],
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["lang", "global", "local"]
      }
    ]
  }
}
