{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the desktop window. fs:scope is allow=** + deny-list for sensitive locations (credentials, browser profiles, shell history, app's own session DB); the scope policy applies to both plugin-fs (frontend-initiated) AND the Rust-side safe_io commands which reuse app.fs_scope().is_allowed(...). Full rationale + threat model + finding history: see the project design doc § 'fs:scope policy'.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "dialog:default",
    "fs:default",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.azure" },
        { "path": "$HOME/.azure/**" },
        { "path": "$HOME/.gcloud" },
        { "path": "$HOME/.gcloud/**" },
        { "path": "$HOME/.docker" },
        { "path": "$HOME/.docker/**" },
        { "path": "$HOME/.kube" },
        { "path": "$HOME/.kube/**" },
        { "path": "$HOME/.config/gh/**" },
        { "path": "$HOME/.config/git/credentials" },
        { "path": "$HOME/.cargo/credentials" },
        { "path": "$HOME/.cargo/credentials.toml" },
        { "path": "$HOME/.git-credentials" },
        { "path": "$HOME/.npmrc" },
        { "path": "$HOME/.netrc" },
        { "path": "$HOME/.pypirc" },
        { "path": "$APPDATA/Microsoft/Credentials/**" },
        { "path": "$APPDATA/Microsoft/Crypto/**" },
        { "path": "$APPDATA/Microsoft/Protect/**" },
        { "path": "$APPDATA/Microsoft/Vault/**" },
        { "path": "$APPDATA/Microsoft/Windows/Start Menu/**" },
        { "path": "$APPDATA/Microsoft/Windows/SendTo/**" },
        { "path": "$APPDATA/Mozilla/**" },
        { "path": "$APPDATA/Thunderbird/**" },
        { "path": "$APPDATA/Signal/**" },
        { "path": "$APPDATA/Telegram Desktop/**" },
        { "path": "$APPDATA/PuTTY/**" },
        { "path": "$LOCALDATA/Microsoft/Credentials/**" },
        { "path": "$LOCALDATA/Microsoft/Vault/**" },
        { "path": "$LOCALDATA/Microsoft/Windows/Start Menu/**" },
        { "path": "$LOCALDATA/Google/Chrome/User Data/**" },
        { "path": "$LOCALDATA/Chromium/User Data/**" },
        { "path": "$LOCALDATA/Microsoft/Edge/User Data/**" },
        { "path": "$LOCALDATA/BraveSoftware/**" },
        { "path": "$LOCALDATA/Mozilla/**" },
        { "path": "$LOCALDATA/Microsoft/WindowsApps/**" },
        { "path": "$LOCALDATA/Packages/**" },
        { "path": "$APPDATA/Code/User/**" },
        { "path": "$APPDATA/npm/**" },
        { "path": "$APPDATA/yarn/**" },
        { "path": "$APPDATA/com.koagaroon.ssahdrify/**" },
        { "path": "$LOCALDATA/com.koagaroon.ssahdrify/**" },
        { "path": "$HOME/.bash_history" },
        { "path": "$HOME/.zsh_history" },
        { "path": "$LOCALDATA/Microsoft/Windows/PowerShell/PSReadLine/**" },
        { "path": "$HOME/.local/share/fish/fish_history" },
        { "path": "$HOME/.viminfo" },
        { "path": "$HOME/.lesshst" },
        { "path": "$HOME/.local/share/keyrings/**" },
        { "path": "$HOME/.gnome2/keyrings/**" },
        { "path": "$HOME/.kde/share/apps/kwallet/**" }
      ]
    }
  ]
}
