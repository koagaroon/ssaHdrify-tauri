{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions. Font directories are intentionally excluded from fs:scope — font files are read by Rust commands via std::fs::read with provenance validation (see fonts.rs), not through the Tauri FS plugin. The FS scope applies only to frontend-initiated file operations. IMPORTANT: fs:scope MUST be '**' (all paths) for BOTH read and write — $HOME only covers C:\\Users\\<user>, but input files commonly live on other drives (D:\\, E:\\, etc.). Output files are saved to the same directory as the input, so write scope must be equally broad. Restricting to $HOME breaks multi-drive workflows on Windows. This is a local desktop tool where the user picks files via native dialog, so broad fs scope is acceptable. SECURITY NOTE: the Rust backend commands (read_text_detect_encoding, subset_font) enforce their own access controls (extension whitelist, provenance cache) independent of fs:scope.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-copy-file",
    "fs:allow-rename",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }],
      "deny": [
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.azure" },
        { "path": "$HOME/.azure/**" },
        { "path": "$HOME/.gcloud" },
        { "path": "$HOME/.gcloud/**" },
        { "path": "$HOME/.docker" },
        { "path": "$HOME/.docker/**" },
        { "path": "$HOME/.kube" },
        { "path": "$HOME/.kube/**" },
        { "path": "$HOME/.config/gh/**" },
        { "path": "$HOME/.config/git/credentials" },
        { "path": "$HOME/.cargo/credentials" },
        { "path": "$HOME/.cargo/credentials.toml" },
        { "path": "$HOME/.git-credentials" },
        { "path": "$HOME/.npmrc" },
        { "path": "$HOME/.netrc" },
        { "path": "$HOME/.pypirc" },
        { "path": "$APPDATA/Microsoft/Credentials/**" },
        { "path": "$APPDATA/Microsoft/Crypto/**" },
        { "path": "$APPDATA/Microsoft/Protect/**" },
        { "path": "$APPDATA/Microsoft/Vault/**" },
        { "path": "$APPDATA/Microsoft/Windows/Start Menu/**" },
        { "path": "$APPDATA/Microsoft/Windows/SendTo/**" },
        { "path": "$APPDATA/Mozilla/**" },
        { "path": "$APPDATA/Thunderbird/**" },
        { "path": "$APPDATA/Signal/**" },
        { "path": "$APPDATA/Telegram Desktop/**" },
        { "path": "$APPDATA/PuTTY/**" },
        { "path": "$LOCALDATA/Microsoft/Credentials/**" },
        { "path": "$LOCALDATA/Microsoft/Vault/**" },
        { "path": "$LOCALDATA/Microsoft/Windows/Start Menu/**" },
        { "path": "$LOCALDATA/Google/Chrome/User Data/**" },
        { "path": "$LOCALDATA/Chromium/User Data/**" },
        { "path": "$LOCALDATA/Microsoft/Edge/User Data/**" },
        { "path": "$LOCALDATA/BraveSoftware/**" },
        { "path": "$LOCALDATA/Mozilla/**" },
        { "path": "$LOCALDATA/Microsoft/WindowsApps/**" },
        { "path": "$LOCALDATA/Packages/**" },
        { "path": "$APPDATA/Code/User/**" },
        { "path": "$APPDATA/npm/**" },
        { "path": "$APPDATA/yarn/**" },
        { "path": "$APPDATA/com.koagaroon.ssahdrify/**" },
        { "path": "$LOCALDATA/com.koagaroon.ssahdrify/**" }
      ]
    }
  ]
}
