{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the desktop window. fs:scope is allow=** + deny-list for sensitive locations (credentials, browser profiles, shell history, jump lists, app's own session DB); plugin-fs command ACL scope stays defined here for policy parity, and Rust-side safe_io / encoding commands build an app-owned tauri::fs::Scope from this same JSON via fs_policy.rs. Frontend overwrite preflight and file reads/writes/copy/rename route through Rust commands with extension, reparse-point, and scope checks; no direct plugin-fs file command grant is exposed to the WebView. Deny-list order: $HOME → $DATA → $LOCALDATA → $APPDATA/$APPLOCALDATA → app-private. Full rationale + threat model + finding history: see the project design doc § 'fs:scope policy'. Deny-list integrity is pinned by tests/test_capabilities.rs (R17 W17.5 A-R17-49).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "dialog:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }],
      "deny": [
        { "path": "$HOME/.aws" },
        { "path": "$HOME/.aws/**" },
        { "path": "$HOME/.azure" },
        { "path": "$HOME/.azure/**" },
        { "path": "$HOME/.bash_history" },
        { "path": "$HOME/.cargo/**" },
        { "path": "$HOME/.config/Code/User/**" },
        { "path": "$HOME/.config/JetBrains/**" },
        { "path": "$HOME/.config/gh/**" },
        { "path": "$HOME/.config/git/credentials" },
        { "path": "$HOME/.config/op/**" },
        { "path": "$HOME/.docker" },
        { "path": "$HOME/.docker/**" },
        { "path": "$HOME/.gcloud" },
        { "path": "$HOME/.gcloud/**" },
        { "path": "$HOME/.git-credentials" },
        { "path": "$HOME/.gnome2/keyrings/**" },
        { "path": "$HOME/.gnupg" },
        { "path": "$HOME/.gnupg/**" },
        { "path": "$HOME/.kde/share/apps/kwallet/**" },
        { "path": "$HOME/.kube" },
        { "path": "$HOME/.kube/**" },
        { "path": "$HOME/.lesshst" },
        { "path": "$HOME/.local/share/JetBrains/**" },
        { "path": "$HOME/.local/share/fish/fish_history" },
        { "path": "$HOME/.local/share/keyrings/**" },
        { "path": "$HOME/.netrc" },
        { "path": "$HOME/.npmrc" },
        { "path": "$HOME/.pypirc" },
        { "path": "$HOME/.ssh" },
        { "path": "$HOME/.ssh/**" },
        { "path": "$HOME/.viminfo" },
        { "path": "$HOME/.zsh_history" },
        { "path": "$HOME/Library/Application Support/Code/User/**" },
        { "path": "$HOME/Library/Application Support/JetBrains/**" },

        { "path": "$DATA/Code/User/**" },
        { "path": "$DATA/Docker/**" },
        { "path": "$DATA/JetBrains/**" },
        { "path": "$DATA/Microsoft/Credentials/**" },
        { "path": "$DATA/Microsoft/Crypto/**" },
        { "path": "$DATA/Microsoft/Office/Recent/**" },
        { "path": "$DATA/Microsoft/Protect/**" },
        { "path": "$DATA/Microsoft/Vault/**" },
        { "path": "$DATA/Microsoft/Windows/Recent/**" },
        { "path": "$DATA/Microsoft/Windows/SendTo/**" },
        { "path": "$DATA/Microsoft/Windows/Start Menu/**" },
        { "path": "$DATA/Mozilla/**" },
        { "path": "$DATA/PuTTY/**" },
        { "path": "$DATA/Signal/**" },
        { "path": "$DATA/Telegram Desktop/**" },
        { "path": "$DATA/Thunderbird/**" },
        { "path": "$DATA/npm/**" },
        { "path": "$DATA/yarn/**" },

        { "path": "$LOCALDATA/BraveSoftware/**" },
        { "path": "$LOCALDATA/Chromium/User Data/**" },
        { "path": "$LOCALDATA/Docker/**" },
        { "path": "$LOCALDATA/Google/Chrome/User Data/**" },
        { "path": "$LOCALDATA/JetBrains/**" },
        { "path": "$LOCALDATA/Lens/**" },
        { "path": "$LOCALDATA/Microsoft/Credentials/**" },
        { "path": "$LOCALDATA/Microsoft/Edge/User Data/**" },
        { "path": "$LOCALDATA/Microsoft/Vault/**" },
        { "path": "$LOCALDATA/Microsoft/Windows/PowerShell/PSReadLine/**" },
        { "path": "$LOCALDATA/Microsoft/Windows/Start Menu/**" },
        { "path": "$LOCALDATA/Microsoft/WindowsApps/**" },
        { "path": "$LOCALDATA/Mozilla/**" },
        { "path": "$LOCALDATA/Packages/**" },

        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$DATA/ssahdrify/**" }
      ]
    }
  ]
}
