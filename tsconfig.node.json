{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    /* Cover the scripts/*.mjs build helpers under typecheck so a typo
       / undefined binding surfaces at `tsc -b` time, not at `node
       scripts/...` run time. `allowJs` is required for .mjs in
       `include`; `checkJs` turns on actual type-checking against the
       JSDoc on scripts/lib/app-version.mjs. The umbrella build script
       (`package.json::build`) runs `tsc -b` before `vite build`, so
       this catches drift in the shared build path. */
    "allowJs": true,
    "checkJs": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["vite.config.ts", "scripts/**/*.mjs"]
}
